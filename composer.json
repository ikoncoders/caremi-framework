{
    "name": "ikoncoders/caremi-framework",
    "description": "A Small modular PHP framework Build for web applications",
    "keywords": [
        "ikonizer-base","magma-framework","php","framework","project"
    ],
    "type": "library",
    "time": "2023-09-28",
    "readme": "https://github.com/ikoncoders/ikonizer-magma/blob/master/README.md",
    "support": {
        "email": "ikoncoders@gmail.com",
        "source": "https://github.com/ikoncoders/caremi-framework",
        "wiki": "https://github.com/ikoncoders/caremi-framework/wiki",
        "issues": "https://github.com/ikoncoders/caremi-framework/issues"
    },
    "homepage": "https://github.com/ikoncoders",
    "license": "MIT",
    "authors": [{
        "name": "ikoncoders",
        "email": "ikoncoders@gmail.com",
        "role": "Developer"
    }],
    "minimum-stability": "dev",
    "require": {
        "php":"7.4.2|^8.0",
        "ext-mbstring": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-simplexml": "*",
        "symfony/yaml": "^5.2",
        "flatbase/flatbase": "^0.4.1",     
        "twig/twig": "^3.1",
        "symfony/http-foundation": "^5.2",
        "paragonie/anti-csrf": "^2.3",
        "symfony/dotenv": "^5.2",
        "symfony/asset": "^5.2",      
        "symfony/serializer-pack": "^1.0",
        "phpmailer/phpmailer": "^6.2"  
    },
    "autoload": {
        "psr-4": {
            "Caremi\\": "src/caremi"
        },
        "files": []
    },
    "autoload-dev": {
        "psr-4": {
            "Caremi\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "mockery/mockery": "^1.4"
    },
    "suggest": {
        "paragonise/anti-csrf": "Added for csrf form protection"
    }
    
}